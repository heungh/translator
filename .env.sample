# AWS Configuration for Translator
# For local development, copy this to .env and fill in values
# Config priority: SSM Parameter Store → .env → hardcoded defaults

# S3 (prompt version glossary JSON storage)
# Default: my-translation-prompts (auto-created if not exists)
PROMPT_S3_BUCKET=

# DynamoDB (prompt version metadata + translation jobs)
# Default: translator (auto-created if not exists)
PROMPT_DYNAMO_TABLE=

# AWS Region for S3 & DynamoDB
# Default: ap-northeast-2
PROMPT_AWS_REGION=

# Translation Cache (Valkey / Redis)
# Format: redis://<host>:<port>/<db> or rediss:// for TLS
# Default: redis://localhost:6379/0
# Leave empty to use in-memory cache (no persistence across restarts)
VALKEY_URL=
